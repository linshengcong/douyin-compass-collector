# 钉钉通知使用显式开关，真实值只写入本机 .env。
DINGTALK_ENABLED=true
DINGTALK_WEBHOOK_URL=
DINGTALK_SECRET=

# OSS 只在正式 CSV 发布成功后上传，并生成最长 7 天的私有下载链接。
OSS_ENABLED=false
OSS_REGION=
OSS_ENDPOINT=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_OBJECT_PREFIX=compass
OSS_DOWNLOAD_URL_EXPIRES_SECONDS=604800

# 公开网页数据独立于私有 CSV 下载链路；只公开 OSS 的 WEB_PUBLIC_PREFIX 前缀。
WEB_ENABLED=false
WEB_PUBLIC_PREFIX=compass/web
# GitHub Pages 等静态站的公开入口；设置后无需等待 Vercel 部署。
WEB_SITE_URL=

# Vercel 仅在网页数据上传成功后触发；Deploy Hook 与 API Token 都必须视为密钥。
VERCEL_ENABLED=false
VERCEL_DEPLOY_HOOK_URL=
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
VERCEL_SITE_URL=
